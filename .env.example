# DocuSearch Environment Variables
# Copy this file to .env and configure with your values
# WARNING: Keep .env secure - it contains API keys and secrets!

# ============================================================================
# Shikomi Embedding Service
# ============================================================================
# gRPC target for the Shikomi embedding service
SHIKOMI_GRPC_TARGET=localhost:50051

# Use mock embeddings (for testing without the real model)
# Set to false to use real colnomic-embed-multimodal-7b model
SHIKOMI_USE_MOCK=true

# ============================================================================
# Koji Database
# ============================================================================
# Path to the Koji database (created automatically on first use)
KOJI_DB_PATH=data/koji.db

# ============================================================================
# ASR Configuration - MLX Backend (Metal GPU Acceleration)
# ============================================================================
ASR_ENABLED=true
ASR_BACKEND=mlx
ASR_MODEL=turbo
ASR_LANGUAGE=en
ASR_WORD_TIMESTAMPS=true
ASR_TEMPERATURE=0.0
ASR_MAX_TIME_CHUNK=30.0
ASR_BATCH_SIZE=12

# ============================================================================
# HuggingFace Model Cache
# ============================================================================
# Directory for caching MLX Whisper models
HF_HOME=/path/to/model/cache

# ============================================================================
# Logging
# ============================================================================
LOG_LEVEL=INFO
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL

# ============================================================================
# LLM Configuration for Research Bot
# ============================================================================
# Provider: openai, anthropic, google, or local
LLM_PROVIDER=openai

# Model selection (provider-specific)
# OpenAI: gpt-4, gpt-4-turbo, gpt-3.5-turbo
# Anthropic: claude-3-opus-20240229, claude-3-sonnet-20240229
# Google: gemini-pro, gemini-ultra
LLM_MODEL=gpt-5-nano

# ============================================================================
# LLM API Keys
# ============================================================================
# Set the API key(s) for the provider(s) you plan to use

# OpenAI API Key
OPENAI_API_KEY=your-openai-api-key-here

# Anthropic API Key (for Claude models)
# ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Google API Key (for Gemini models)
# GOOGLE_API_KEY=your-google-api-key-here

# ============================================================================
# Ngrok Configuration (for vision mode - external image access)
# ============================================================================
# Get your auth token from: https://dashboard.ngrok.com/get-started/your-authtoken
# NGROK_AUTHTOKEN=your-ngrok-authtoken-here

# ============================================================================
# Port Configuration (42xxx scheme for tkr-managed services)
# ============================================================================
# Frontend ports
VITE_FRONTEND_PORT=3333
VITE_UI_PORT=42888

# Network access - allowed hostnames/IPs for Vite dev server
VITE_ALLOWED_HOSTS=localhost,127.0.0.1

# ============================================================================
# Service URLs Configuration
# ============================================================================
WORKER_URL=http://localhost:8002
RESEARCH_API_URL=http://localhost:8004
FRONTEND_URL=http://localhost:3333

# Frontend service URLs (VITE_ prefix required for Vite to expose to browser)
VITE_WORKER_URL=http://localhost:8002
VITE_RESEARCH_API_URL=http://localhost:8004
VITE_FRONTEND_URL=http://localhost:3333

# ============================================================================
# Processing Worker Configuration
# ============================================================================
WORKER_PORT=8002
DEVICE=mps
# Options: mps (Metal), cuda (NVIDIA), cpu
MODEL_PRECISION=fp16
# Options: fp16, fp32

# ============================================================================
# Upload Configuration
# ============================================================================
UPLOADS_DIR=data/uploads
MAX_FILE_SIZE_MB=100
SUPPORTED_FORMATS=pdf,doc,docx,pptx,xlsx,html,xhtml,md,asciidoc,csv,mp3,wav,vtt,png,jpg,jpeg,tiff,bmp,webp

# ============================================================================
# CORS Configuration
# ============================================================================
ALLOWED_ORIGINS=http://localhost

# ============================================================================
# Research API Configuration
# ============================================================================
RESEARCH_API_PORT=8004

# ============================================================================
# Vision Mode
# ============================================================================
# Enable vision-based research (requires ngrok for external image URLs)
RESEARCH_VISION_ENABLED=true

# ============================================================================
# Local LLM Preprocessing Configuration
# ============================================================================
# Enable local LLM preprocessing to reduce foundation model costs
# Requires: LLM_PROVIDER=mlx, MLX model downloaded

LOCAL_PREPROCESS_ENABLED=false
LOCAL_PREPROCESS_STRATEGY=compress
LOCAL_PREPROCESS_THRESHOLD=7.0
LOCAL_PREPROCESS_MAX_SOURCES=20

# ============================================================================
# Local Preprocessing (MLX) - Harmony Format Optimization
# ============================================================================
USE_HARMONY_PROMPTS=true
MLX_REASONING_EFFORT=low
MLX_MODEL_PATH=/path/to/gpt-oss-20b-MLX-4bit
MLX_MAX_TOKENS=4000
